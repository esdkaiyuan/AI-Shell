{
  "name": "@ai-shell/desktop",
  "version": "0.1.0",
  "description": "AI Shell Desktop Application",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:main:bundle && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:main:bundle": "node scripts/build-main.mjs",
    "build:renderer": "vite build",
    "start": "electron .",
    "package": "electron-builder"
  },
  "dependencies": {
    "@ai-shell/core": "workspace:*",
    "asynckit": "^0.4.0",
    "combined-stream": "^1.0.8",
    "delayed-stream": "^1.0.0",
    "electron-store": "^8.1.0",
    "es-set-tostringtag": "^2.1.0",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.5",
    "hasown": "^2.0.2",
    "https-proxy-agent": "^5.0.1",
    "mime-db": "^1.52.0",
    "mime-types": "^2.1.35",
    "node-pty": "^1.0.0",
    "proxy-from-env": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.14.1",
    "ssh2": "^1.15.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.21.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.aishell.app",
    "productName": "AI Shell",
    "icon": "build/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
