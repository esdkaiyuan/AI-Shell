{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/main",
    "rootDir": "./src/main",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/main/**/*"],
  "exclude": ["node_modules", "dist"]
}
