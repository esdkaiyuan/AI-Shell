{
  "name": "ai-shell",
  "version": "0.1.0",
  "description": "AI-powered cross-platform shell terminal with multi-provider support",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "dev:mobile": "pnpm --filter @ai-shell/mobile start",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter desktop build",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "node-pty-prebuilt-multiarch": "0.10.1-pre.5",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "shell",
    "terminal",
    "ai",
    "ssh",
    "electron",
    "react-native"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "cpu-features",
      "electron",
      "esbuild",
      "node-pty",
      "ssh2"
    ]
  },
  "author": "esdkaiyuan",
  "license": "MIT",
  "packageManager": "pnpm@10.34.1"
}
